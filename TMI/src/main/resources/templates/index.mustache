{{>layouts/header}}
<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>메인 페이지</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: #000032;
            color: white;
            font-family: Pretendard, -apple-system, BlinkMacSystemFont, system-ui,
            Roboto, 'Helvetica Neue', 'Segoe UI', 'Apple SD Gothic Neo',
            'Noto Sans KR', 'Malgun Gothic', sans-serif;
            text-align: center;
        }

        .notice {
            margin-top: 10px;
        }

        #noticeBar {
            width: 60%;
            height: 55px;
            background-color: #efeff2;
            border-radius: 10px;
            text-align: left;
            padding: 12px;
            font-size: 23px;
            font-weight: bold;
            margin: 50px auto;
            color: #000032;
        }

        .container {
            display: flex;
            justify-content: center;
            align-items: flex-start;
            flex-wrap: wrap;
            max-width: 1200px;
            margin: auto;
            padding: 20px;
        }

        .bbs {
            flex: 1;
            width: 700px;
            height: 320px;
            background-color: #efeff2;
            border-radius: 12px;
            padding: 25px 0;
            text-align: center;
            color: #000032;
            font-size: 25px;
            font-weight: bold;
            margin-top: 70px;
            margin-right: 30px;
        }

        .post {
            margin: 15px 0;
        }

        .post a {
            color: #000032;
            font-size: 22px;
            font-weight: bold;
            text-decoration: none;
            background-color: #efeff2;
            padding: 5px 10px;
            border-radius: 8px;
            transition: background-color 0.3s;
        }

        .calendar {
            flex: 1;
            width: 450px;
            text-align: center;
            margin-left: 30px;
            display: flex;
            flex-direction: column;
        }

        .header {
            margin-bottom: 20px;
        }

        .year-month {
            font-size: 30px;
            margin-bottom: 10px;
        }

        .nav {
            display: flex;
            justify-content: center;
            align-items: center;
            margin-bottom: 20px;
        }

        .nav-btn {
            width: 40px;
            height: 40px;
            font-size: 18px;
            line-height: 40px;
            background-color: transparent;
            border: none;
            cursor: pointer;
            color: white;
            transition: background-color 0.3s;
        }

        .nav-btn:hover {
            background-color: rgba(255, 255, 255, 0.1);
        }

        .go-today {
            width: 100px;
            border-left: 1px solid #333333;
            border-right: 1px solid #333333;
        }

        .days {
            display: flex;
            margin-bottom: 10px;
        }

        .day {
            flex: 1;
            font-weight: bold;
        }

        .dates {
            display: flex;
            flex-wrap: wrap;
            height: auto;
            border: 1px solid #333333;
        }

        .date {
            flex-basis: calc(100% / 7);
            padding: 15px;
            text-align: center;
            border-bottom: 1px solid #333333;
            border-left: 1px solid #333333;
            font-size: 18px;
        }

        .day:nth-child(7n + 1),
        .date:nth-child(7n + 1) {
            color: #d13e3e;
        }

        .day:nth-child(7n),
        .date:nth-child(7n) {
            color: #396ee2;
        }

        .other {
            opacity: 0.3;
        }

        .today {
            position: relative;
            color: #000032;
        }

        .today::before {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 20px;
            height: 20px;
            background-color: #f5ffb6;
            border-radius: 50%;
            content: '';
            z-index: -1;
        }

        #studyIcon {
            position: fixed;
            bottom: 100px;
            right: 150px;
            font-size: 150px;
            cursor: pointer;
            background-color: transparent;
        }

        .boldPost {
            font-weight: bold;
        }

        .scheduleDay {
            text-align: end;
        }

        .scheduleContent {
            text-align: left;
        }

        .othersContent {
            color: #ff8888;
        }

        .schContent {
            color: #8db1ff;
        }

        .clbContent {
            color: #f5ffb6;
        }
    </style>
</head>
<body>
<iframe
        src="./menu2.html"
        frameborder="0"
        scrolling="no"
        style="width: 100%; height: 100px"
></iframe>

<div class="notice">
    <div class="notice" id="noticeBar">📢 공지 예시글</div>
</div>

<div class="container">
    <div class="bbs">
        🔥인기글
        <div class="post">
            <a href="./postEx.html"
            >1️⃣ <span class="boldPost">[공지사항]&nbsp;</span>인기 게시글 제목
                1</a
            >
        </div>
        <div class="post">
            <a href="./postEx.html">2️⃣ 인기 게시글 제목 2</a>
        </div>
        <div class="post">
            <a href="./postEx.html"
            >3️⃣ <span class="boldPost">[Q&A]&nbsp;</span>인기 게시글 제목 3</a
            >
        </div>
        <div class="post">
            <a href="./postEx.html">4️⃣ 인기 게시글 제목 4</a>
        </div>
        <div class="post">
            <a href="./postEx.html">5️⃣ 인기 게시글 제목 5</a>
        </div>
    </div>

    <div class="calendarContainer">
        <div class="calendar">
            <div class="header">
                <div class="year-month"></div>
                <div class="nav">
                    <button class="nav-btn go-prev" onclick="prevMonth()">
                        &lt;
                    </button>
                    <button class="nav-btn go-today" onclick="goToday()">
                        Today
                    </button>
                    <button class="nav-btn go-next" onclick="nextMonth()">
                        &gt;
                    </button>
                </div>
                <div class="main">
                    <div class="days">
                        <div class="day">일</div>
                        <div class="day">월</div>
                        <div class="day">화</div>
                        <div class="day">수</div>
                        <div class="day">목</div>
                        <div class="day">금</div>
                        <div class="day">토</div>
                    </div>
                    <div class="dates"></div>
                </div>
            </div>
            <script src="calendar.js"></script>
        </div>
        <br />
        <div>
            <div>
                <div>
                    <span class="scheduleDay">2024.06.06&nbsp;&nbsp;</span>
                    <span class="scheduleContent"
                    ><span class="othersContent">[기타]</span>&nbsp;현충일</span
                    >
                </div>
                <div>
                    <span class="scheduleDay">2024.06.10~16&nbsp;&nbsp;</span>
                    <span class="scheduleContent">
                <span class="schContent">[학사]&nbsp;</span> 보강 및 기말고사
                기간
              </span>
                </div>
                <div>
                    <span class="scheduleDay">2024.06.17&nbsp;&nbsp;</span>
                    <span class="scheduleContent">
                <span class="schContent">[학사]&nbsp;</span> 하계 계절학기 기간
              </span>
                </div>
                <div>
                    <span class="scheduleDay">2024.06.21&nbsp;&nbsp;</span>
                    <span class="scheduleContent">
                <span class="clbContent">[동아리]&nbsp;</span> 모의 토익 응시 및
                그룹별 해설
              </span>
                </div>
                <div>
                    <span class="scheduleDay">2024.06.20~24&nbsp;&nbsp;</span>
                    <span class="scheduleContent">
                <span class="schContent">[학사]&nbsp;</span> 1학기 성적 확인 및
                이의 신청 기간
              </span>
                </div>
            </div>
        </div>
    </div>
</div>

<span id="studyIcon">📖</span>

<iframe
        src="./footer.html"
        frameborder="0"
        scrolling="no"
        style="width: 100%; height: 50px"
></iframe>
</body>
</html>
{{>layouts/footer}}