{{>layouts/header}}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>로그인 페이지</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            background-color: #000032;
            font-family: Pretendard, -apple-system, BlinkMacSystemFont, system-ui,
            Roboto, 'Helvetica Neue', 'Segoe UI', 'Apple SD Gothic Neo',
            'Noto Sans KR', 'Malgun Gothic', sans-serif;
            text-align: center;
            color: white;
        }

        .login {
            margin-top: 200px;
        }

        #inputNum,
        #inputPwd {
            font-size: 20px;
            padding: 5px 10px;
            line-height: 20px;
            margin-bottom: 10px;
            width: 470px;
            height: 50px;
            border: 1px solid white;
            border-radius: 7px;
            background-color: #ccccd6;
            color: black;
        }

        #loginBtn {
            font-size: 25px;
            font-weight: 700;
            padding: 5px 10px;
            line-height: 25px;
            margin-top: 20px;
            margin-bottom: 10px;
            width: 500px;
            height: 65px;
            background-color: white;
            border-radius: 15px;
            color: #000032;
        }

        #links {
            margin-top: 20px;
            color: white;
            font-size: 20px;
        }

        a {
            color: white;
            text-decoration: none;
        }
    </style>
</head>
<body>
<iframe
        src="./menu.html"
        frameborder="0"
        scrolling="no"
        style="width: 100%; height: 100px"
></iframe>

<div class="login">
    <input id="inputNum" type="text" placeholder="학번을 입력하세요." />
    <br />
    <input
            id="inputPwd"
            type="password"
            placeholder="비밀번호를 입력하세요."
    />
    <br />
    <button id="loginBtn" onclick="location.href='./index.html'">
        로그인
    </button>
    <br />

    <div id="links">
        <a href="./join.html">회원가입 &nbsp; </a>
        | <a href="./findPwd.html"> &nbsp; 비밀번호 찾기</a>
    </div>
</div>

<iframe
        src="./footer.html"
        frameborder="0"
        scrolling="no"
        style="width: 100%; height: 80px"
></iframe>
</body>
</html>
{{>layouts/footer}}
