{{> header}}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>회원 탈퇴하기</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            background-color: #000032;
            font-family: Pretendard, -apple-system, BlinkMacSystemFont, system-ui, Roboto, 'Helvetica Neue', 'Segoe UI', 'Apple SD Gothic Neo', 'Noto Sans KR', 'Malgun Gothic', sans-serif;
            text-align: center;
            color: white;
        }

        .cancel {
            margin-top: 200px;
        }

        #inputPwd,
        #inputNum {
            font-size: 20px;
            padding: 5px 10px;
            line-height: 20px;
            margin-bottom: 10px;
            width: 470px;
            height: 50px;
            border: 1px solid white;
            border-radius: 7px;
            background-color: #ccccd6;
            color: black;
        }

        #cancelBtn {
            font-size: 25px;
            font-weight: 700;
            padding: 5px 10px;
            line-height: 25px;
            margin-top: 20px;
            margin-bottom: 10px;
            width: 500px;
            height: 65px;
            background-color: white;
            border-radius: 15px;
            color: #000032;
        }

        #desc {
            margin-top: 10px;
            font-size: large;
            color: #ccccd6;
        }
    </style>
</head>
<body>
<iframe src="./menu2.html" style="width: 100%; height: 100px"></iframe>

<div class="cancel">
    <input id="inputNum" type="text" placeholder="{{lang.hakbun}}" />
    <br />
    <input id="inputPwd" type="password" placeholder="{{lang.password}}" />
    <br />
    <button id="cancelBtn" onclick="alert('{{lang.withdrawalCompleted}}')">
        {{lang.withdrawal}}
    </button>
    <div id="desc">
        ※ {{lang.restrictionDescription}}
    </div>

    <iframe src="./footer.html" style="width: 100%; height: 80px"></iframe>
</div>
</body>
</html>
{{> footer}}
