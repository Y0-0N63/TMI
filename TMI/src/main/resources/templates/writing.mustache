{{>layouts/header}}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>게시글 작성</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            background-color: #000032;
            font-family: Pretendard, -apple-system, BlinkMacSystemFont, system-ui,
            Roboto, 'Helvetica Neue', 'Segoe UI', 'Apple SD Gothic Neo',
            'Noto Sans KR', 'Malgun Gothic', sans-serif;
            text-align: center;
            color: white;
        }

        .container {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: calc(100vh - 180px);
        }

        .writing {
            margin-top: 50px;
            border: 3px solid white;
            width: 70%;
            height: 550px;
            border-radius: 20px;
            text-align: left;
            padding-left: 50px;
        }

        #sort {
            margin-top: 30px;
            width: 150px;
            height: 40px;
            font-size: 20px;
            font-weight: 500;
            text-align: left;
            border: none;
        }

        #inputTitle {
            width: 90%;
            height: 50px;
            padding: 10px 15px;
            line-height: 50px;
            text-align: left;
            border: none;
            font-size: 23px;
            font-weight: bold;
        }

        #inputContent {
            font-size: 22px;
            padding: 10px 15px;
            margin-bottom: 10px;
            width: 90%;
            height: 350px;
            color: white;
            text-align: left;
            border: none;
        }

        #inputTitle::placeholder {
            color: white;
            font-size: 23px;
            font-weight: bold;
        }

        #inputContent::placeholder {
            font-size: 22px;
            font-weight: 500;
            color: white;
        }

        .btn {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            margin-top: 20px;
            gap: 20px;
            width: 70%;
        }

        #inqBtn {
            font-size: 25px;
            font-weight: 700;
            padding: 5px 10px;
            line-height: 25px;
            width: 250px;
            height: 65px;
            background-color: white;
            border-radius: 15px;
            color: #000032;
        }

        #cancelBtn {
            font-size: 25px;
            font-weight: 700;
            padding: 5px 10px;
            line-height: 25px;
            width: 250px;
            height: 65px;
            background-color: #000032;
            border: 3px solid white;
            border-radius: 15px;
            color: white;
        }

        .hidden-file-input {
            display: none;
        }

        #clip {
            width: 60px;
            cursor: pointer;
        }
    </style>
</head>
<body>
<iframe
        src="./menu2.html"
        frameborder="0"
        scrolling="no"
        style="width: 100%; height: 100px"
></iframe>

<div class="container">
    <div class="writing">
        <select name="sort" id="sort">
            <option value="notice">공지사항</option>
            <option value="q&a">Q&A</option>
            <option value="none">말머리 없음</option>
        </select>
        <br />
        <textarea
                id="inputTitle"
                placeholder="제목을 작성해주세요."
                scrolling="no"
        ></textarea>
        <br />
        <textarea
                id="inputContent"
                placeholder="게시글을 작성해주세요."
                scrolling="no"
        ></textarea>
        <br />
    </div>

    <div class="btn">
        <img src="/TMI/img/clip.png" id="clip" />
        <input type="file" id="fileInput" class="hidden-file-input" />
        <button id="inqBtn" onclick="alert('게시글을 업로드하였습니다.')">
            업로드
        </button>
        <button id="cancelBtn" onclick="location.href='./index.html'">
            취소
        </button>
    </div>
</div>

<iframe
        src="./footer.html"
        frameborder="0"
        scrolling="no"
        style="width: 100%; height: 80px"
></iframe>

<script>
    document.getElementById('clip').addEventListener('click', function () {
        document.getElementById('fileInput').click();
    });

    document
            .getElementById('fileInput')
            .addEventListener('change', function (event) {
                const file = event.target.files[0];
                if (file) {
                    alert(`Selected file: ${file.name}`);
                }
            });
</script>
</body>
</html>
{{>layouts/footer}}
