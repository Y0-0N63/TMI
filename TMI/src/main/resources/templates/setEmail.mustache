{{>layouts/header}}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>이메일 찾기</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            background-color: #000032;
            font-family: Pretendard, -apple-system, BlinkMacSystemFont, system-ui,
            Roboto, 'Helvetica Neue', 'Segoe UI', 'Apple SD Gothic Neo',
            'Noto Sans KR', 'Malgun Gothic', sans-serif;
            text-align: center;
            color: white;
        }

        .setEmail {
            margin-top: 200px;
        }

        #inputPwd,
        #inputNewPwd,
        #inputNewPwdAgain {
            font-size: 20px;
            padding: 5px 10px;
            line-height: 20px;
            margin-bottom: 10px;
            width: 470px;
            height: 50px;
            border: 1px solid white;
            border-radius: 7px;
            background-color: #ccccd6;
            color: black;
        }

        #setBtn {
            font-size: 25px;
            font-weight: 700;
            padding: 5px 10px;
            line-height: 25px;
            margin-top: 20px;
            margin-bottom: 10px;
            width: 500px;
            height: 65px;
            background-color: white;
            border-radius: 15px;
            color: #000032;
        }

        #cancelBtn{
            font-size: 25px;
            font-weight: 700;
            padding: 5px 10px;
            line-height: 25px;
            width: 500px;
            height: 65px;
            background-color: #000032;
            border: 3px solid white;
            border-radius: 15px;
            color: white;
        }

        a {
            color: white;
            text-decoration: none;
        }
    </style>
</head>
<body>
<iframe
        src="./menu2.html"
        frameborder="0"
        scrolling="no"
        style="width: 100%; height: 100px"
></iframe>

<div class="setEmail">
    <input id="inputPwd" type="text" placeholder="새로운 이메일 주소를 입력하세요." />
    <br />
    <input
            id="inputNewPwd"
            type="text"
            placeholder="비밀번호를 입력하세요"
    />
    <br>
    <button id="setBtn" onclick="alert('이메일이 재설정되었습니다.')">
        이메일 변경
    </button>
</div>
    <iframe
            src="./footer.html"
            frameborder="0"
            scrolling="no"
            style="width: 100%; height: 80px"
    ></iframe>
</body>
</html>
{{>layouts/footer}}
