{{>layouts/header}}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>문의하기</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            background-color: #000032;
            font-family: Pretendard, -apple-system, BlinkMacSystemFont, system-ui,
            Roboto, 'Helvetica Neue', 'Segoe UI', 'Apple SD Gothic Neo',
            'Noto Sans KR', 'Malgun Gothic', sans-serif;
            text-align: center;
            color: white;
        }

        .inquiry {
            margin-top: 50px;
        }

        #text {
            color: white;
            font-size: 35px;
            font-weight: 700;
            margin-bottom: 30px;
            margin-left: 270px;
            text-align: left;
        }

        #inqutInquiry {
            font-size: 22px;
            padding: 10px 15px;
            margin-bottom: 10px;
            width: 70%;
            height: 400px;
            border: 3px solid white;
            border-radius: 10px;
            color: white;
            text-align: left;
            vertical-align: top;
            resize: none;
            box-sizing: border-box;
            overflow: hidden;
        }

        #inqutInquiry::placeholder {
            font-size: 22px;
            font-weight: 500;
            text-align: center;
            line-height: 380px;
            color: white;
        }

        #inqBtn {
            font-size: 25px;
            font-weight: 700;
            padding: 5px 10px;
            line-height: 25px;
            margin-top: 20px;
            margin-bottom: 10px;
            width: 250px;
            height: 65px;
            background-color: white;
            border-radius: 15px;
            color: #000032;
        }

        #cancelBtn{
            font-size: 25px;
            font-weight: 700;
            padding: 5px 10px;
            line-height: 25px;
            width: 250px;
            height: 65px;
            background-color: #000032;
            border: 3px solid white;
            border-radius: 15px;
            color: white;
        }

        .btn{
            text-align: right;
            margin-right: 270px;
        }

    </style>
</head>
<body>
<iframe
        src="./menu2.html"
        frameborder="0"
        scrolling="no"
        style="width: 100%; height: 100px"
></iframe>

<div class="inquiry">
    <div id="text">문의하기</div>
    <textarea id="inqutInquiry" placeholder="문의할 내용을 입력해주세요." scrolling="no"></textarea>
    <br />

    <div class="btn">
        <button id="inqBtn" onclick="alert('메일을 전송하였습니다.')">
            문의하기
        </button>
        <button id="cancelBtn" onclick="location.href='./index.html'">
            취소
        </button>
    </div>
</div>
    <iframe
            src="./footer.html"
            frameborder="0"
            scrolling="no"
            style="width: 100%; height: 80px"
    ></iframe>
</body>
</html>
{{>layouts/footer}}
